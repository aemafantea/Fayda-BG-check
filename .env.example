# ---------- Fayda eSignet OIDC ----------
FAYDA_BASE_URL=https://esignet.ida.fayda.et
FAYDA_CLIENT_ID=
FAYDA_CLIENT_SECRET=
FAYDA_REDIRECT_URI=https://YOUR_DOMAIN/auth/fayda-callback
FAYDA_SCOPES=openid profile email
FAYDA_ACR_VALUES=mosip:idp:acr:generated-code

# ---------- Email (Resend) ----------
RESEND_API_KEY=re_...
EMAIL_FROM=BG-Check <noreply@yourdomain.com>

# ---------- Flutter (passed via --dart-define) ----------
FAYDA_REDIRECT_SCHEME=io.supabase.faydabgcheck
